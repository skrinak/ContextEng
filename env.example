# ContextEng — Environment Configuration (sample)
#
# This is a reference .env for an AgentCore-first AWS agentic app. Yours is
# unique to your project — copy to .env and fill in. The product-specific block
# at the bottom (external tool/data APIs) is just an example; replace it.
#
# .env files contain highly sensitive information. Never commit them. In
# production, prefer AWS Secrets Manager, and prefer AgentCore Gateway/Identity
# credential providers over .env for *tool* credentials (see docs/AGENTCORE_FIRST.md).

# ==================================
# AWS Core (Required)
# ==================================
AWS_REGION=TBD                          # one region only (us-east-1 only for a CloudFront ACM cert)
AWS_ACCESS_KEY_ID=TBD                   # local dev only; production uses IAM roles
AWS_SECRET_ACCESS_KEY=TBD

# ==================================
# Agent path — AgentCore (PRIMARY)
# ==================================
# The browser invokes the Runtime directly via Cognito Identity Pool SigV4 —
# no API Gateway hop. The Identity Pool authenticated role must be granted
# bedrock-agentcore:InvokeAgentRuntime.
COGNITO_IDENTITY_POOL_ID=TBD            # vends SigV4 creds for the Runtime invoke
AGENTCORE_RUNTIME_ARN=TBD              # arn:aws:bedrock-agentcore:<region>:<acct>:runtime/<id>
AGENTCORE_MEMORY_ID=TBD                # dialogue/event store (can be source-of-truth from t=0)
AGENTCORE_GATEWAY_MCP_URL=TBD          # MCP tool plane endpoint (web search, GitHub, Slack targets)

# Bedrock models (resolved through your model factory; Bedrock inference profiles)
BEDROCK_MODEL_ID_PRIMARY=TBD           # e.g. role/expert agents
BEDROCK_MODEL_ID_FAST=TBD              # e.g. auditor / judge / cheap steps
BEDROCK_EMBED_MODEL_ID=TBD             # only if you embed outside Memory's native retrieval

# Per-tool credentials live in AgentCore Gateway/Identity credential providers,
# NOT here. Add a .env entry only for a tool you have not yet moved to Gateway.

# ==================================
# CRUD path — API Gateway + Lambda (support)
# ==================================
AWS_API_GATEWAY_URL=TBD                # REST, CRUD only — never the agent path
COGNITO_USER_POOL_ID=TBD              # human IdP; JWT authorizer for the CRUD path
COGNITO_USER_POOL_CLIENT_ID=TBD
COGNITO_DOMAIN=TBD

DYNAMODB_KMS_KEY_ID=TBD                # customer-managed KMS key (alias preferred over raw ID)
EVENTBRIDGE_BUS_NAME=TBD
EVENTBRIDGE_BUS_ARN=TBD
S3_ARTIFACTS_BUCKET=TBD

# ==================================
# Frontend (Vite build-time, VITE_*)
# ==================================
VITE_API_URL=TBD                       # API Gateway invoke URL (CRUD path)
VITE_COGNITO_USER_POOL_ID=TBD
VITE_COGNITO_CLIENT_ID=TBD
VITE_COGNITO_IDENTITY_POOL_ID=TBD      # required for the SigV4 Runtime invoke
VITE_AGENTCORE_RUNTIME_ARN=TBD         # parameterize the ARN — do not hardcode it in source

# ==================================
# Security (Required)
# ==================================
ENCRYPTION_KEY=TBD                     # 256-bit key for client-side encryption of sensitive data
JWT_SECRET=TBD                         # residual: inbound webhook reply tokens, if not on Identity
JWT_EXPIRATION=TBD
JWT_REFRESH_EXPIRATION=TBD
CSP_NONCE=TBD

# ==================================
# Application Configuration
# ==================================
APP_ENVIRONMENT=TBD                    # development | staging | production
APP_BASE_URL=TBD
APP_VERSION=TBD
APP_BUILD_NUMBER=TBD

# ==================================
# Compliance & Observability
# ==================================
SOC2_COMPLIANCE_MODE=TBD
AUDIT_LOGGING_ENABLED=TBD
AUDIT_LOG_LEVEL=TBD
# OTEL is on by default in the Runtime container (aws-opentelemetry-distro);
# OTEL_TRACES_EXPORTER=none is a valid stopgap if platform span export 400s.
OTEL_TRACES_EXPORTER=TBD

EULA_VERSION=TBD
TERMS_VERSION=TBD
PRIVACY_POLICY_VERSION=TBD

# ==================================
# Development & Testing
# ==================================
DEV_TOOLS_ENABLED=TBD
TEST_MODE=TBD
MOCK_API_RESPONSES=TBD                 # mock data only from a data source — never hardcoded in src
PERFORMANCE_MONITORING=TBD
ERROR_REPORTING=TBD

# ==================================
# Rate Limiting
# ==================================
# Prefer AgentCore Policy (Cedar) for per-user/per-key model-call quotas over
# hand-rolled counters. These are app-level HTTP limits only.
API_RATE_LIMIT_REQUESTS_PER_MINUTE=TBD
BEDROCK_DAILY_LIMIT=TBD                # per-user model-call cap (move to Cedar Policy when adopted)

# ==================================
# Product-specific external APIs  (EXAMPLE — replace with your product's)
# ==================================
# Illustrative only (this sample came from a financial app). Move these behind
# an AgentCore Gateway tool target + credential provider once the agent calls them.
EXAMPLE_DATA_API_BASE_URL=TBD
EXAMPLE_DATA_API_KEY=TBD

# ==================================
# IMPORTANT SECURITY NOTES
# ==================================
# 1. Never commit actual API keys or secrets to version control.
# 2. Use AWS Secrets Manager (residual) and AgentCore Gateway/Identity (tool creds) in production.
# 3. Parameterize account-bound IDs (Runtime ARN, Memory ID, KMS key, Cognito/CloudFront IDs)
#    so a fresh-account migration re-points them in lockstep.
# 4. Rotate keys regularly; use different keys per environment.
# 5. Validate all environment variables on startup.
